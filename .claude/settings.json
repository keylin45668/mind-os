{
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash mind-os/scripts/hook-stop-guard.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash mind-os/scripts/hook-compliance-check.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash mind-os/scripts/hook-output-validator.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "bash mind-os/scripts/hook-session-rating.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash mind-os/scripts/hook-schema-guard.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash mind-os/scripts/hook-post-compact.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash mind-os/scripts/hook-session-reset.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash mind-os/scripts/hook-turn-counter.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash mind-os/scripts/hook-must-run-check.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
